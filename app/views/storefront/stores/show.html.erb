<div class="mb-10" data-reveal>
  <%= render "storefront/shared/influencer", store: @store %>
  <p class="mt-4 muted">Limited drops. When the timer's up or the stock's gone, it's gone.</p>
</div>

<% if @products.any? %>
  <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
    <% @products.each do |product| %>
      <%# Russian-doll fragment cache: card HTML is rendered once and reused
          until the product changes. %>
      <% cache product do %>
        <%= link_to storefront_store_product_path(@store, product.id),
              class: "product-card panel flex flex-col transition hover:border-[#c9a84c]/40", data: { reveal: "" } do %>
          <div class="relative flex h-44 items-center justify-center overflow-hidden bg-[#0c0c0c]">
            <% if product.image.attached? %>
              <%= image_tag product.image.variant(:card), class: "h-full w-full object-cover", loading: "lazy", alt: product.name %>
            <% else %>
              <%= image_tag demo_product_image(product, width: 600, height: 400), class: "h-full w-full object-cover", loading: "lazy", alt: product.name %>
            <% end %>
            <% if product.discount_percent %>
              <span class="absolute left-2 top-2 rounded bg-[#2a1414] px-2 py-1 text-xs font-medium text-red-300"><%= product.discount_percent %>% off</span>
            <% end %>
          </div>
          <div class="flex flex-1 flex-col p-5">
            <h2 class="font-medium"><%= product.name %></h2>
            <div class="mt-1 flex items-baseline gap-2">
              <span class="display text-2xl font-bold gold"><%= number_to_currency(product.price) %></span>
              <% if product.original_price %>
                <span class="text-sm muted line-through"><%= number_to_currency(product.original_price) %></span>
              <% end %>
            </div>
            <p class="mt-1 text-xs muted"><%= product.stock %> left</p>
            <span class="btn mt-4 w-full text-center">View drop</span>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="panel py-20 text-center muted">No drops available right now.</div>
<% end %>
