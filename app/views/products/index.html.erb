<div class="rounded-lg border bg-white p-8 shadow-sm">
  <div class="mb-6 flex items-center justify-between">
    <h1 class="text-2xl font-bold">Products</h1>
    <%= link_to "New product", new_product_path,
          class: "rounded bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-gray-700" %>
  </div>

  <% if @products.any? %>
    <table class="w-full text-sm">
      <thead class="border-b text-left text-gray-500">
        <tr>
          <th class="py-2">Name</th>
          <th class="py-2">Price</th>
          <th class="py-2">Stock</th>
          <th class="py-2"></th>
        </tr>
      </thead>
      <tbody>
        <% @products.each do |product| %>
          <tr class="border-b last:border-0">
            <td class="py-2"><%= product.name %></td>
            <td class="py-2"><%= number_to_currency(product.price) %></td>
            <td class="py-2"><%= product.stock %></td>
            <td class="py-2 text-right">
              <%= link_to "Edit", edit_product_path(product), class: "text-gray-700 underline" %>
              <% if policy(product).destroy? %>
                <%= button_to "Delete", product_path(product), method: :delete,
                      class: "ml-2 text-red-600 underline",
                      form: { class: "inline" },
                      data: { turbo_confirm: "Delete this product?" } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-gray-500">No products yet. Add your first one.</p>
  <% end %>
</div>
