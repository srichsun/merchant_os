<div class="rounded-lg border bg-white p-8 shadow-sm">
  <p class="text-sm text-gray-500">Store</p>
  <h1 class="text-2xl font-bold"><%= @tenant.name %></h1>

  <dl class="mt-6 space-y-2 text-sm">
    <div class="flex gap-2">
      <dt class="w-24 text-gray-500">Signed in</dt>
      <dd><%= current_user.email %></dd>
    </div>
    <div class="flex gap-2">
      <dt class="w-24 text-gray-500">Role</dt>
      <dd>
        <span class="rounded bg-gray-100 px-2 py-0.5 text-xs font-medium"><%= current_user.role %></span>
      </dd>
    </div>
  </dl>

  <div class="mt-6 flex gap-4">
    <%= link_to "Manage products →", products_path,
          class: "font-medium text-gray-900 underline" %>
    <%= link_to "View storefront →", storefront_store_path(@tenant),
          class: "font-medium text-gray-900 underline" %>
  </div>
</div>
