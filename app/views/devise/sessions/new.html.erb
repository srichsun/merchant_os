<div class="panel mx-auto max-w-sm p-8">
  <h2 class="display mb-6 text-2xl font-bold">Log in</h2>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <div class="mb-4">
      <%= f.label :email, class: "field-label" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "field-input" %>
    </div>

    <div class="mb-4">
      <%= f.label :password, class: "field-label" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "field-input" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <label class="mb-6 flex items-center gap-2 text-sm soft">
        <%= f.check_box :remember_me %> Remember me
      </label>
    <% end %>

    <%= f.submit "Log in", class: "btn w-full text-center" %>
  <% end %>

  <div class="mt-6 text-sm">
    <%= render "devise/shared/links" %>
  </div>
</div>
