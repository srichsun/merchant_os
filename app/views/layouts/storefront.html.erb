<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= @store&.name || "Store" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <script>document.documentElement.classList.add("js");</script>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,700&family=Inter:wght@400;500;600&family=Martian+Mono:wght@400;500&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen">
    <header class="border-b border-[#1e1e1e] bg-[#0c0c0c]">
      <div class="mx-auto max-w-5xl px-6 py-6">
        <a href="<%= storefront_store_path(@store) %>" class="display text-2xl font-bold tracking-tight">
          <%= @store.name %>
        </a>
      </div>
    </header>

    <% if notice %>
      <div class="mx-auto mt-5 max-w-5xl px-6">
        <p class="border border-[#2a2620] bg-[#111] px-4 py-3 text-sm text-[#c9a84c]"><%= notice %></p>
      </div>
    <% end %>
    <% if alert %>
      <div class="mx-auto mt-5 max-w-5xl px-6">
        <p class="border border-red-900/50 bg-[#170f0f] px-4 py-3 text-sm text-red-300"><%= alert %></p>
      </div>
    <% end %>

    <main class="mx-auto max-w-5xl px-6 py-12" data-controller="reveal">
      <%= yield %>
    </main>

    <footer class="mx-auto max-w-5xl px-6 py-12 mono text-xs tracking-widest muted">
      <%= @store.name %> · POWERED BY MERCHANTOS
    </footer>
  </body>
</html>
