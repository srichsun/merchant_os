<div class="panel mx-auto max-w-sm p-8">
  <h2 class="display mb-6 text-2xl font-bold">Forgot your password?</h2>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="mb-6">
      <%= f.label :email, class: "field-label" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "field-input" %>
    </div>

    <%= f.submit "Send reset instructions", class: "btn w-full text-center" %>
  <% end %>

  <div class="mt-6 text-sm">
    <%= render "devise/shared/links" %>
  </div>
</div>
