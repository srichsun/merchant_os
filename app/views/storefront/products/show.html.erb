<div class="mx-auto max-w-3xl" data-reveal>
  <%= link_to "← #{@store.name}", storefront_store_path(@store), class: "mono text-xs tracking-widest muted" %>

  <div class="mt-6 grid gap-8 md:grid-cols-2">
    <%# Product image %>
    <div class="panel flex aspect-square items-center justify-center overflow-hidden bg-[#0c0c0c]">
      <% if @product.image.attached? %>
        <%= image_tag @product.image.variant(:card), class: "h-full w-full object-cover", alt: @product.name %>
      <% else %>
        <span class="display text-7xl font-bold muted"><%= @product.name.first %></span>
      <% end %>
    </div>

    <%# Details %>
    <div>
      <% case @product.sale_status %>
      <% when :on_sale %>
        <span class="kicker text-[#c9a84c]">🔥 熱賣中</span>
      <% when :upcoming %>
        <span class="kicker muted">即將開賣</span>
      <% when :sold_out %>
        <span class="kicker text-red-400">已售完</span>
      <% when :ended %>
        <span class="kicker muted">活動已結束</span>
      <% end %>

      <h1 class="display mt-3 text-3xl font-bold tracking-tight"><%= @product.name %></h1>

      <%# Limited price vs original price %>
      <div class="mt-4 flex flex-wrap items-baseline gap-3">
        <span class="display text-3xl font-bold gold"><%= number_to_currency(@product.price) %></span>
        <% if @product.original_price %>
          <span class="text-lg muted line-through"><%= number_to_currency(@product.original_price) %></span>
        <% end %>
        <% if @product.discount_percent %>
          <span class="rounded bg-[#2a1414] px-2 py-1 text-xs font-medium text-red-300">省 <%= @product.discount_percent %>%</span>
        <% end %>
      </div>

      <%# Scarcity + countdown (deadline shown static now; ticks live after the JS step) %>
      <div class="mt-4 space-y-1 text-sm">
        <p class="muted">剩 <span class="gold font-medium"><%= @product.stock %></span> 件</p>
        <% if @product.upcoming? %>
          <p class="muted">開賣倒數：<%= @product.sale_starts_at.strftime("%m/%d %H:%M") %></p>
        <% elsif @product.on_sale? && @product.sale_ends_at %>
          <p class="muted">結束倒數：<%= @product.sale_ends_at.strftime("%m/%d %H:%M") %></p>
        <% end %>
      </div>

      <%# Buy action — only live while on sale %>
      <div class="mt-8">
        <% if @product.on_sale? %>
          <%= link_to "立即搶購", storefront_store_checkout_path(@store, @product.id),
                      class: "btn block w-full text-center text-lg" %>
        <% else %>
          <span class="btn pointer-events-none block w-full cursor-not-allowed text-center opacity-40">
            <%= { sold_out: "已售完", upcoming: "尚未開賣", ended: "活動已結束" }[@product.sale_status] %>
          </span>
        <% end %>
      </div>
    </div>
  </div>
</div>
