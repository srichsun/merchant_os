<%= form_with model: product do |f| %>
  <% if product.errors.any? %>
    <div class="mb-4 rounded border border-red-200 bg-red-50 p-3 text-sm text-red-800">
      <ul class="list-inside list-disc">
        <% product.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <%= f.label :name, class: "mb-1 block text-sm font-medium" %>
    <%= f.text_field :name,
          class: "w-full rounded border border-gray-300 px-3 py-2 focus:border-gray-500 focus:outline-none" %>
  </div>

  <div class="mb-4">
    <%= f.label :price_cents, "Price (in cents)", class: "mb-1 block text-sm font-medium" %>
    <%= f.number_field :price_cents,
          class: "w-full rounded border border-gray-300 px-3 py-2 focus:border-gray-500 focus:outline-none" %>
  </div>

  <div class="mb-6">
    <%= f.label :stock, class: "mb-1 block text-sm font-medium" %>
    <%= f.number_field :stock,
          class: "w-full rounded border border-gray-300 px-3 py-2 focus:border-gray-500 focus:outline-none" %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit class: "cursor-pointer rounded bg-gray-900 px-4 py-2 font-medium text-white hover:bg-gray-700" %>
    <%= link_to "Cancel", products_path, class: "text-sm text-gray-500" %>
  </div>
<% end %>
