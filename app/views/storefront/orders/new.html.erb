<div class="panel mx-auto max-w-md p-8">
  <h1 class="display text-2xl font-bold">Checkout</h1>
  <p class="mt-1 mb-6 soft">
    <%= @product.name %> · <span class="gold"><%= number_to_currency(@product.price) %></span>
    <span class="muted">(<%= @product.stock %> in stock)</span>
  </p>

  <%= form_with url: storefront_store_orders_path(@store), method: :post, data: { turbo: false } do %>
    <%= hidden_field_tag :product_id, @product.id %>

    <div class="mb-4">
      <%= label_tag "order[customer_name]", "Full name", class: "field-label" %>
      <%= text_field_tag "order[customer_name]", nil, required: true, autocomplete: "name", class: "field-input" %>
    </div>

    <div class="mb-4">
      <%= label_tag "order[customer_email]", "Email", class: "field-label" %>
      <%= email_field_tag "order[customer_email]", nil, required: true, autocomplete: "email", class: "field-input" %>
    </div>

    <div class="mb-4">
      <%= label_tag "order[phone]", "Phone", class: "field-label" %>
      <%= telephone_field_tag "order[phone]", nil, required: true, autocomplete: "tel", class: "field-input" %>
    </div>

    <div class="mb-4">
      <%= label_tag "order[shipping_address]", "Shipping address", class: "field-label" %>
      <%= text_area_tag "order[shipping_address]", nil, required: true, rows: 2, autocomplete: "street-address", class: "field-input" %>
    </div>

    <div class="mb-6">
      <%= label_tag "order[quantity]", "Quantity", class: "field-label" %>
      <%= number_field_tag "order[quantity]", 1, min: 1, max: @product.stock, class: "field-input" %>
    </div>

    <fieldset class="mb-6">
      <legend class="field-label">Payment method</legend>
      <div class="space-y-2">
        <label class="flex cursor-pointer items-center gap-3 border border-[#2a2620] bg-[#0c0c0c] px-4 py-3 transition has-[:checked]:border-[#c9a84c]">
          <%= radio_button_tag :payment_method, "stripe", true, class: "accent-[#c9a84c]" %>
          <span class="text-sm">Credit card <span class="muted">· Stripe</span></span>
        </label>
        <label class="flex cursor-pointer items-center gap-3 border border-[#2a2620] bg-[#0c0c0c] px-4 py-3 transition has-[:checked]:border-[#c9a84c]">
          <%= radio_button_tag :payment_method, "ecpay", false, class: "accent-[#c9a84c]" %>
          <span class="text-sm">ECPay <span class="muted">· 綠界</span></span>
        </label>
      </div>
    </fieldset>

    <%= submit_tag "Pay now", class: "btn w-full text-center" %>
  <% end %>

  <%= link_to "← Back to store", storefront_store_path(@store), class: "link-soft mt-5 inline-block text-sm" %>
</div>
