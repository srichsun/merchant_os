<div class="panel mx-auto max-w-md p-8 text-center">
  <h1 class="display text-2xl font-bold">Redirecting to ECPay…</h1>
  <p class="mt-2 soft">You're being taken to ECPay's secure payment page.</p>

  <%# Posts to ECPay (external) — drop Rails' CSRF token; it's not an ECPay param %>
  <%= form_tag @action_url, method: :post, id: "ecpay-form", authenticity_token: false, data: { turbo: false } do %>
    <% @fields.each do |name, value| %>
      <%= hidden_field_tag name, value %>
    <% end %>
    <%= submit_tag "Continue to ECPay", class: "btn mt-6 w-full" %>
  <% end %>
</div>

<script>
  document.getElementById("ecpay-form").submit();
</script>
