<div class="mx-auto max-w-3xl">
  <h1 class="mb-1 text-3xl font-bold"><%= @store.name %></h1>
  <p class="mb-6 text-gray-500">Welcome to our store</p>

  <%= form_with url: storefront_store_path(@store), method: :get, class: "mb-8" do %>
    <%= text_field_tag :q, params[:q], placeholder: "Search products…",
          class: "w-full rounded border border-gray-300 px-3 py-2 focus:border-gray-500 focus:outline-none" %>
  <% end %>

  <% if @products.any? %>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <% @products.each do |product| %>
        <div class="rounded-lg border bg-white p-5 shadow-sm">
          <h2 class="font-medium"><%= product.name %></h2>
          <p class="mt-1 text-lg font-bold"><%= number_to_currency(product.price) %></p>
          <p class="text-sm text-gray-500"><%= product.stock %> in stock</p>

          <%= button_to "Buy", storefront_store_orders_path(@store, product_id: product.id),
                class: "mt-3 w-full rounded bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-gray-700" %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-gray-500">No products available right now.</p>
  <% end %>
</div>
