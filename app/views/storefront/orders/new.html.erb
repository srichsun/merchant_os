<div class="panel mx-auto max-w-md p-8">
  <h1 class="display text-2xl font-bold">Checkout</h1>
  <p class="mt-1 mb-6 soft">
    <%= @product.name %> · <span class="gold"><%= number_to_currency(@product.price) %></span>
    <span class="muted">(<%= @product.stock %> in stock)</span>
  </p>

  <%= form_with url: storefront_store_orders_path(@store), method: :post do %>
    <%= hidden_field_tag :product_id, @product.id %>

    <div class="mb-4">
      <%= label_tag "order[customer_email]", "Email", class: "field-label" %>
      <%= email_field_tag "order[customer_email]", nil, required: true, class: "field-input" %>
    </div>

    <div class="mb-6">
      <%= label_tag "order[quantity]", "Quantity", class: "field-label" %>
      <%= number_field_tag "order[quantity]", 1, min: 1, max: @product.stock, class: "field-input" %>
    </div>

    <%= submit_tag "Pay now", class: "btn w-full text-center" %>
  <% end %>

  <%= link_to "← Back to store", storefront_store_path(@store), class: "link-soft mt-5 inline-block text-sm" %>
</div>
