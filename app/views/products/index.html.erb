<div class="panel p-8">
  <div class="mb-6 flex items-center justify-between">
    <h1 class="display text-3xl font-bold">Products</h1>
    <%= link_to "New product", new_product_path, class: "btn" %>
  </div>

  <%= form_with url: products_path, method: :get, class: "mb-6 max-w-md" do %>
    <%= text_field_tag :q, params[:q], placeholder: "Search products…", class: "field-input" %>
  <% end %>

  <% if @products.any? %>
    <table class="w-full text-sm">
      <thead class="border-b border-[#1e1e1e] text-left muted">
        <tr>
          <th class="py-3 font-medium">Name</th>
          <th class="py-3 font-medium">Price</th>
          <th class="py-3 font-medium">Stock</th>
          <th class="py-3"></th>
        </tr>
      </thead>
      <tbody>
        <% @products.each do |product| %>
          <tr class="border-b border-[#161616] last:border-0">
            <td class="py-3 font-medium"><%= product.name %></td>
            <td class="py-3 gold"><%= number_to_currency(product.price) %></td>
            <td class="py-3"><%= product.stock %></td>
            <td class="py-3 text-right">
              <%= link_to "Edit", edit_product_path(product), class: "link-soft" %>
              <% if policy(product).destroy? %>
                <%= button_to "Delete", product_path(product), method: :delete,
                      class: "ml-3 text-red-400 underline hover:text-red-300",
                      form: { class: "inline" },
                      data: { turbo_confirm: "Delete this product?" } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="py-12 text-center muted">No products yet. Add your first one.</p>
  <% end %>
</div>
