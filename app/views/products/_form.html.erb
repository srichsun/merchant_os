<%= form_with model: product do |f| %>
  <% if product.errors.any? %>
    <div class="mb-4 border border-red-900/50 bg-[#170f0f] p-3 text-sm text-red-300">
      <ul class="list-inside list-disc">
        <% product.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <%= f.label :name, class: "field-label" %>
    <%= f.text_field :name, class: "field-input" %>
  </div>

  <div class="mb-4">
    <%= f.label :description, class: "field-label" %>
    <%= f.text_area :description, rows: 3, class: "field-input",
          placeholder: "Short pitch for the drop (shown on the product page)." %>
  </div>

  <div class="mb-4 grid grid-cols-2 gap-4">
    <div>
      <%= f.label :price_cents, "Sale price (cents)", class: "field-label" %>
      <%= f.number_field :price_cents, class: "field-input" %>
    </div>
    <div>
      <%= f.label :original_price_cents, "Original price (cents)", class: "field-label" %>
      <%= f.number_field :original_price_cents, class: "field-input" %>
    </div>
  </div>

  <div class="mb-4">
    <%= f.label :stock, class: "field-label" %>
    <%= f.number_field :stock, class: "field-input" %>
  </div>

  <div class="mb-4 grid grid-cols-2 gap-4">
    <div>
      <%= f.label :sale_starts_at, "Sale starts", class: "field-label" %>
      <%= f.datetime_local_field :sale_starts_at, class: "field-input" %>
    </div>
    <div>
      <%= f.label :sale_ends_at, "Sale ends", class: "field-label" %>
      <%= f.datetime_local_field :sale_ends_at, class: "field-input" %>
    </div>
  </div>

  <div class="mb-6">
    <%= f.label :image, "Product photo", class: "field-label" %>
    <% if product.image.attached? %>
      <%= image_tag product.image.variant(:card), class: "mb-2 h-24 w-24 rounded object-cover" %>
    <% end %>
    <%= f.file_field :image, accept: "image/*", class: "field-input" %>
  </div>

  <div class="flex items-center gap-4">
    <%= f.submit "Save", class: "btn" %>
    <%= link_to "Cancel", products_path, class: "link-soft text-sm" %>
  </div>
<% end %>
